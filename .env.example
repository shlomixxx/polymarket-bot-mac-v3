# בוט Polymarket — משתני סביבה
# להעתיק ל־.env ולמלא ערכים משלך.
# המנוע (engine/main.py) טוען את .env אוטומטית משורש הפרויקט בעת ההפעלה.

# המתנה בין טיקי אסטרטגיה (שניות). ברירת מחדל ב־scripts/run-engine.sh: 0.1
# STRATEGY_TICK_SLEEP_SEC=0.1

# ─── לוגר קריאות שרת (לצורך איתור קריאות כפולות) ───
# כשהמנוע פעיל, כל קריאת HTTP נכתבת ל־engine/logs/requests.jsonl כשורת JSONL.
# גם הקריאות מה־frontend נשלחות ל־POST /api/_log/client-request ונכתבות לאותו קובץ.
# ברירת מחדל: 1 (פעיל). לכיבוי הזמני: LOG_REQUESTS=0
# LOG_REQUESTS=1

# ─── מסלול תשואה בגרף (דמו) — POSITION_TRACKING_PATH_MAX ───
# כמה נקודות אחרונות לשמור בזנגל (rolling) לכל פוזיציה — רק אורך ההיסטוריה בגרף, לא «מהירות קו».
# מהירות הדגימה נקבעת בקוד המנוע (למשל אינטרוול ~1s בין נקודות + מצב volatile צפוף יותר) —
# המשתנה הזה לא מאט ולא מאיץ דגימות; הוא רק מגדיל כמה דקות אחורה רואים כשמעלים את N.
#
# איך לרשום: שורה אחת בלי רווחים סביב ה־=, מספר שלם בלי מרכאות, למשל:
#   POSITION_TRACKING_PATH_MAX=600
# אם השורה חסרה או מוערת (#) — ברירת מחדל מהקוד: 240 (כמו ההגדרה המקורית).
# טווח מותר: 64 עד 10000.
# דוגמאות לערך: 240 (ברירת מחדל), 600 או 1200 אם רוצים לראות היסטוריה ארוכה יותר באותה דגימה.
# אחרי שינוי — להפעיל מחדש את המנוע.
# POSITION_TRACKING_PATH_MAX=240

# ──────────────────────────────────────────────
# מפתח פרטי למסחר ב־CLOB של Polymarket.
# אפשר גם לשמור דרך הממשק (נשמר ב־Keychain של המערכת).
# POLYMARKET_PRIVATE_KEY=0x...

# סוג חתימה:
#   0 = EOA (ברירת מחדל) — מפתח רגיל / ייצוא מ־MetaMask
#   1 = Poly-proxy — ארנק דפדפן (חשבון באתר Polymarket)
#   2 = Gnosis Safe / multisig אחר
# אם נרשמת ב־polymarket.com, נסה 1.
POLYMARKET_SIGNATURE_TYPE=0

# ─── חשבון דרך האתר (ייצאת מפתח מ־Polymarket) — עשה כך: ───
# 1) ב־polymarket.com נכנסים לפרופיל (Profile).
# 2) פותחים את החלון «Your Polymarket Wallet Address» (מופיעה כתובת עם כפתור Copy).
# 3) מדביקים בדיוק את אותה כתובת לשורה למטה — כן, זו הכתובת הנכונה ל־FUNDER
#    (אותה כתובת שמקושרת ל־Portfolio / Cash באתר).
# 4) משאירים POLYMARKET_SIGNATURE_TYPE=1 (אם יש invalid signature — נסה 2).
# 5) שומרים את הקובץ .env ומפעילים מחדש את המנוע.
#
# POLYMARKET_SIGNATURE_TYPE=1
# POLYMARKET_FUNDER=0x........................................
#
# (השורה עם FUNDER — הדבק את הכתובת המלאה מהחלון שלך, לא את הנקודות.)

# מתג כיבוי: לערוך ל־0 כדי לחסום שליחת הזמנות לייב לחלוטין.
# POLYMARKET_LIVE=1
