# Polymarket Bot — Environment Variables
# Copy to .env and fill in your values.

# ──────────────────────────────────────────────
# Private key for Polymarket CLOB trading.
# Can also be saved via the UI (stored in OS keychain).
# POLYMARKET_PRIVATE_KEY=0x...

# Signature type:
#   0 = EOA (default) — standard private key / MetaMask export
#   1 = Poly-proxy — browser wallet (Polymarket website account)
#   2 = Gnosis Safe / other multisig
# If you created your account on polymarket.com, try 1.
POLYMARKET_SIGNATURE_TYPE=0

# Funder address — the proxy/contract wallet that holds your USDC.
# Required for signature_type 1 or 2 when auto-detection fails.
# Find it in Polymarket Settings → Deposit Address.
# POLYMARKET_FUNDER=0x...

# Kill switch: set to 0 to disable all live order placement.
# POLYMARKET_LIVE=1
